# Copy this to .env and fill in values. Never commit .env.

# Required for Docker volume permissions on Linux (Mac Docker Desktop ignores this).
# Generate with: echo "AIRFLOW_UID=$(id -u)"
AIRFLOW_UID=502

# Optional: override default Airflow UI credentials
# _AIRFLOW_WWW_USER_USERNAME=airflow
# _AIRFLOW_WWW_USER_PASSWORD=airflow
